# Telesink (get this from your Telesink dashboard → Sink → Endpoint)
TELESINK_ENDPOINT="https://app.telesink.com/api/v1/sinks/YOUR_SINK_TOKEN_HERE/events"

ADSENSE_ACCOUNT_ID=accounts/pub-XXXXXXXXXXXXXXXX

# Google OAuth2 credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Optional
POLL_INTERVAL=15m # e.g. 5m, 30m, 1h
